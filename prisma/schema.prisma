generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 모의고사 회차
model Exam {
  id        String   @id @default(cuid())
  name      String   // "2025학년도 6월 모평"
  date      DateTime
  type      String   // "평가원" | "교육청" | "사설"
  grade     String   // "고1" | "고2" | "고3" | "N수"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects Subject[]
  answerKeys AnswerKey[]
}

// 과목 (회차당 여러 과목)
model Subject {
  id              String  @id @default(cuid())
  examId          String
  name            String  // "국어" | "수학" | "영어" | "한국사" | "탐구1" | "탐구2"
  optionName      String? // "언어와매체" | "미적분" | "생활과윤리" 등 선택과목명
  rawScore        Int?    // 원점수
  standardScore   Int?    // 표준점수
  percentile      Float?  // 백분위
  grade           Int?    // 등급 (1~9)
  maxRawScore     Int     @default(100) // 만점 기준
  notes           String? // JSON: 추가 데이터 (시간 기록 등)

  exam      Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions Question[]
  scores    Score[]

  @@index([examId])
}

// 성적 상세 (Subject와 1:1 혹은 추가 기록용)
model Score {
  id            String  @id @default(cuid())
  subjectId     String
  rawScore      Int?
  standardScore Int?
  percentile    Float?
  grade         Int?

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

// 문항별 오답 기록
model Question {
  id          String   @id @default(cuid())
  subjectId   String
  number      Int      // 문항 번호
  unit        String   // 단원 (예: "수열", "현대시")
  topic       String?  // 세부 주제
  difficulty  String   @default("중") // "상" | "중" | "하"
  isCorrect   Boolean  @default(false)
  wrongType   String?  // "개념부족" | "실수" | "시간부족" | "문제이해실패"
  memo        String?  // 자기 분석 메모
  isBookmarked Boolean @default(false) // 즐겨찾기
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([unit])
  @@index([isCorrect])
}

// 과목별 정답지 (자동채점용)
model AnswerKey {
  id          String   @id @default(cuid())
  examId      String
  subjectName String   // "국어" | "수학" 등
  optionName  String?  // 선택과목명
  answers     String   // JSON: {"1":"3","2":"1",...}  정답
  scores      String?  // JSON: {"1":2,"2":3,...}      배점
  totalCount  Int      // 총 문항 수
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, subjectName, optionName])
  @@index([examId])
}

// 단원 마스터 (과목별 단원 목록)
model Unit {
  id          String  @id @default(cuid())
  subjectName String  // "국어" | "수학" 등 (대과목)
  optionName  String? // 선택과목명 (해당 시)
  name        String  // 단원명
  order       Int     @default(0)

  @@unique([subjectName, optionName, name])
  @@index([subjectName])
}
